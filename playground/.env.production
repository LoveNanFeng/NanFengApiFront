VITE_BASE=/

# store 加密密钥 — 生产环境必须通过构建环境变量注入，不应提交到仓库
# VITE_APP_STORE_SECURE_KEY 请在 CI/CD 或部署脚本中设置
VITE_APP_STORE_SECURE_KEY=pSqGjEXG6Z/eCm9UrfiTdwXYUxB6NNjBFuHutO3ZMzX66rb9+jnOCsARSmUznhhUqowqSALeT5XknLIeg1g3kw==

# 接口地址
VITE_GLOB_API_URL=/api

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
